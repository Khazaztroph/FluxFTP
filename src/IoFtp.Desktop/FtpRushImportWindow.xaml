<Window x:Class="IoFtp.Desktop.FtpRushImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Sites" Width="980" Height="560" MinWidth="760" MinHeight="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="16" Background="{StaticResource WindowBrush}">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock x:Name="HeadingText" Text="IMPORT SITES" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="SummaryText" Margin="0,6,0,0" Foreground="{StaticResource MutedTextBrush}"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" IsCancel="True"/>
            <Button Content="Import selected" IsDefault="True" Click="Import_Click"/>
        </StackPanel>
        <DataGrid x:Name="SitesGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" SelectionMode="Extended">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="IMPORT" Binding="{Binding Selected}" Width="70"/>
                <DataGridTextColumn Header="NAME" Binding="{Binding Name}" IsReadOnly="True" Width="170"/>
                <DataGridTextColumn Header="GROUP" Binding="{Binding GroupPath}" IsReadOnly="True" Width="160"/>
                <DataGridTextColumn Header="PROTOCOL" Binding="{Binding Protocol}" IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="HOST" Binding="{Binding Host}" IsReadOnly="True" Width="190"/>
                <DataGridTextColumn Header="PORT" Binding="{Binding Port}" IsReadOnly="True" Width="65"/>
                <DataGridTextColumn Header="REMOTE PATH" Binding="{Binding RemotePath}" IsReadOnly="True" Width="170"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
