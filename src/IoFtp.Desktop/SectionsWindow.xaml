<Window x:Class="IoFtp.Desktop.SectionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sections" Width="1300" Height="620" MinWidth="950" MinHeight="440"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="14" Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
            <Grid><TextBlock Text="SECTIONS" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Default setup imported from ioFTPD" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/></Grid>
        </Border>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Test precheck" Click="TestPrecheck_Click"/><Button Content="Add" Click="Add_Click"/><Button Content="Remove" Click="Remove_Click"/><Button Content="Save" Click="Save_Click"/><Button Content="Close" Click="Close_Click"/>
        </StackPanel>
        <DataGrid x:Name="SectionsGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="NAME" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="SITE" Binding="{Binding Site, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="PATH" Binding="{Binding Path, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
                <DataGridTextColumn Header="HOTKEY" Binding="{Binding Hotkey, UpdateSourceTrigger=PropertyChanged}" Width="90"/>
                <DataGridComboBoxColumn x:Name="ValidationModeColumn" Header="PRECHECK" SelectedItemBinding="{Binding ValidationMode, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                <DataGridTextColumn Header="ALLOW PATTERNS (; separated)" Binding="{Binding AllowPatterns, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
                <DataGridTextColumn Header="DENY PATTERNS (; separated)" Binding="{Binding DenyPatterns, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
