<Window x:Class="IoFtp.Desktop.SiteOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Site Options" Width="700" Height="650" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="18" Background="{StaticResource WindowBrush}">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancel" IsCancel="True"/><Button Content="Save" IsDefault="True" Click="Save_Click"/>
        </StackPanel>
        <StackPanel>
            <TextBlock Text="SITE OPTIONS" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="SiteSummary" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,14"/>
            <TabControl>
                <TabItem Header="Slots &amp; transfers">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Total slots" VerticalAlignment="Center"/><TextBox x:Name="MaxSlotsBox" Grid.Column="1" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Text="Upload slots" VerticalAlignment="Center"/><TextBox x:Name="UploadSlotsBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                        <TextBlock Grid.Row="2" Text="Download slots" VerticalAlignment="Center"/><TextBox x:Name="DownloadSlotsBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>
                        <TextBlock Grid.Row="3" Text="Site priority" VerticalAlignment="Center"/><TextBox x:Name="PriorityBox" Grid.Row="3" Grid.Column="1" Margin="0,4" ToolTip="Higher values increase this site's scheduler score."/>
                        <CheckBox x:Name="AllowUploadBox" Grid.Row="4" Grid.ColumnSpan="2" Content="Allow uploads to this site" Margin="0,8,0,2"/>
                        <CheckBox x:Name="AllowDownloadBox" Grid.Row="5" Grid.ColumnSpan="2" Content="Allow downloads from this site" Margin="0,2"/>
                        <TextBlock Grid.Row="6" Text="Block transfers from" VerticalAlignment="Center"/><TextBox x:Name="BlockFromBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4" ToolTip="Comma-separated site names."/>
                        <TextBlock Grid.Row="7" Text="Block transfers to" VerticalAlignment="Center"/><TextBox x:Name="BlockToBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,4" ToolTip="Comma-separated site names."/>
                    </Grid>
                </TabItem>
                <TabItem Header="Connection behavior">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Base path" VerticalAlignment="Center"/><TextBox x:Name="BasePathBox" Grid.Column="1" Margin="0,4"/>
                        <TextBlock Grid.Row="1" Text="Max idle time (seconds)" VerticalAlignment="Center"/><TextBox x:Name="IdleBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                        <CheckBox x:Name="StayLoggedInBox" Grid.Row="2" Grid.ColumnSpan="2" Content="Stay logged in for browsing" Margin="0,8,0,2"/>
                        <CheckBox x:Name="TlsTransfersBox" Grid.Row="3" Grid.ColumnSpan="2" Content="Prefer secure TLS data transfers" Margin="0,2"/>
                        <CheckBox x:Name="SecureListingsBox" Grid.Row="4" Grid.ColumnSpan="2" Content="Secure file listings (PROT P)" Margin="0,2" ToolTip="Disable for ProFTPD servers that reset TLS LIST data connections. Transfers remain encrypted."/>
                        <CheckBox x:Name="BinaryModeBox" Grid.Row="5" Grid.ColumnSpan="2" Content="Force binary transfer mode" Margin="0,2"/>
                        <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Margin="0,16,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Directory listing mode and TLS certificate policy are configured in Connection details."/>
                    </Grid>
                </TabItem>
            </TabControl>
            <TextBlock x:Name="ErrorText" Foreground="#F07178" Margin="0,10,0,0"/>
        </StackPanel>
    </DockPanel>
</Window>
