<Window x:Class="IoFtp.Desktop.ExternalScriptsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="External Scripts" Width="1150" Height="620" MinWidth="850" MinHeight="430" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="14" Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8"><Grid><TextBlock Text="EXTERNAL SCRIPTS" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/><TextBlock Text="Disabled by default — review commands before enabling" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/></Grid></Border>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"><Button Content="Add" Click="Add_Click"/><Button Content="Browse..." Click="Browse_Click"/><Button Content="Remove" Click="Remove_Click"/><Button Content="Run selected" Click="Run_Click"/><Button Content="Save" Click="Save_Click"/><Button Content="Close" Click="Close_Click"/></StackPanel>
        <Grid><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="130"/></Grid.RowDefinitions>
            <DataGrid x:Name="ScriptsGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"><DataGrid.Columns>
                <DataGridCheckBoxColumn Header="ON" Binding="{Binding Enabled}" Width="45"/><DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="150"/>
                <DataGridComboBoxColumn x:Name="EventColumn" Header="EVENT" SelectedItemBinding="{Binding Event}" Width="125"/><DataGridTextColumn Header="FILE" Binding="{Binding FileName}" Width="240"/>
                <DataGridTextColumn Header="ARGUMENTS" Binding="{Binding Arguments}" Width="220"/><DataGridTextColumn Header="WORKING DIRECTORY" Binding="{Binding WorkingDirectory}" Width="180"/>
                <DataGridTextColumn Header="TIMEOUT" Binding="{Binding TimeoutSeconds}" Width="70"/><DataGridCheckBoxColumn Header="BLOCK" Binding="{Binding BlockOnFailure}" Width="60"/>
            </DataGrid.Columns></DataGrid>
            <TextBox x:Name="OutputBox" Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas" Margin="0,8,0,0"/>
        </Grid>
    </DockPanel>
</Window>
