<Window x:Class="IoFtp.Desktop.MetricsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Metrics" Width="850" Height="560" MinWidth="680" MinHeight="420" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="14" Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,9" Margin="0,0,0,8"><Grid><TextBlock Text="FLUXFTP METRICS" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/><TextBlock x:Name="UpdatedText" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/></Grid></Border>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0"><Button Content="Refresh" Click="Refresh_Click"/><Button Content="Close" Click="Close_Click"/></StackPanel>
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <UniformGrid Columns="4" Margin="0,0,0,8">
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="SITES" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="SitesText" FontSize="24"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="ACTIVE JOBS" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="ActiveText" FontSize="24"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="TOTAL SPEED" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="SpeedText" FontSize="24"/></StackPanel></Border>
                <Border Style="{StaticResource MetricCard}"><StackPanel><TextBlock Text="TRANSFERRED" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="BytesText" FontSize="24"/></StackPanel></Border>
            </UniformGrid>
            <ListView x:Name="MetricsList" Grid.Row="1"><ListView.View><GridView>
                <GridViewColumn Header="METRIC" DisplayMemberBinding="{Binding Name}" Width="260"/><GridViewColumn Header="VALUE" DisplayMemberBinding="{Binding Value}" Width="230"/><GridViewColumn Header="DETAIL" DisplayMemberBinding="{Binding Detail}" Width="280"/>
            </GridView></ListView.View></ListView>
        </Grid>
    </DockPanel>
</Window>
