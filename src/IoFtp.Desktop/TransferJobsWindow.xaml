<Window x:Class="IoFtp.Desktop.TransferJobsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transfer Jobs" Width="1100" Height="620" MinWidth="850" MinHeight="420"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="14" Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
            <Grid>
                <TextBlock Text="ALL TRANSFER JOBS" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
                <TextBlock x:Name="CountersText" HorizontalAlignment="Right" FontFamily="Cascadia Mono, Consolas"/>
            </Grid>
        </Border>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Refresh" Click="Refresh_Click"/>
            <Button Content="Clear all" Click="ClearAll_Click"/>
            <Button Content="Close" Click="Close_Click"/>
        </StackPanel>

        <ListView x:Name="JobsList" FontFamily="Cascadia Mono, Consolas" PreviewMouseRightButtonDown="JobsList_PreviewMouseRightButtonDown">
            <ListView.ContextMenu><ContextMenu><MenuItem Header="Remove job" Click="RemoveJob_Click"/></ContextMenu></ListView.ContextMenu>
            <ListView.View><GridView>
                <GridViewColumn Header="QUEUED" DisplayMemberBinding="{Binding Queued}" Width="75"/>
                <GridViewColumn Header="STARTED" DisplayMemberBinding="{Binding Started}" Width="75"/>
                <GridViewColumn Header="USE" DisplayMemberBinding="{Binding Use}" Width="55"/>
                <GridViewColumn Header="TYPE" DisplayMemberBinding="{Binding Type}" Width="70"/>
                <GridViewColumn Header="NAME" DisplayMemberBinding="{Binding Name}" Width="190"/>
                <GridViewColumn Header="ROUTE" DisplayMemberBinding="{Binding Route}" Width="230"/>
                <GridViewColumn Header="SIZE" DisplayMemberBinding="{Binding Size}" Width="85"/>
                <GridViewColumn Header="FILES" DisplayMemberBinding="{Binding Files}" Width="55"/>
                <GridViewColumn Header="LEFT" DisplayMemberBinding="{Binding Left}" Width="85"/>
                <GridViewColumn Header="SPEED" DisplayMemberBinding="{Binding Speed}" Width="80"/>
                <GridViewColumn Header="DONE" DisplayMemberBinding="{Binding Done}" Width="65"/>
            </GridView></ListView.View>
        </ListView>
    </DockPanel>
</Window>
