<Window x:Class="IoFtp.Desktop.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection" Width="440" Height="540" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="20" Background="{StaticResource WindowBrush}">
        <Grid.ColumnDefinitions><ColumnDefinition Width="105"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.ColumnSpan="2" Text="Connection details" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,18"/>
        <TextBlock Grid.Row="1" Text="Name" VerticalAlignment="Center"/><TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="0,3"/>
        <TextBlock Grid.Row="2" Text="Protocol" VerticalAlignment="Center"/><ComboBox x:Name="ProtocolBox" Grid.Row="2" Grid.Column="1" Margin="0,3" Padding="7,4" SelectionChanged="Protocol_Changed"/>
        <TextBlock Grid.Row="3" Text="Host" VerticalAlignment="Center"/><TextBox x:Name="HostBox" Grid.Row="3" Grid.Column="1" Margin="0,3"/>
        <TextBlock Grid.Row="4" Text="Port" VerticalAlignment="Center"/><TextBox x:Name="PortBox" Grid.Row="4" Grid.Column="1" Margin="0,3"/>
        <TextBlock Grid.Row="5" Text="Username" VerticalAlignment="Center"/><TextBox x:Name="UsernameBox" Grid.Row="5" Grid.Column="1" Margin="0,3"/>
        <TextBlock Grid.Row="6" Text="Password" VerticalAlignment="Center"/><PasswordBox x:Name="PasswordBox" Grid.Row="6" Grid.Column="1" Margin="0,3" Padding="8,5"/>
        <TextBlock Grid.Row="7" Text="Remote path" VerticalAlignment="Center"/><TextBox x:Name="RemotePathBox" Grid.Row="7" Grid.Column="1" Margin="0,3" ToolTip="Remote folder opened after login, for example /MP3"/>
        <CheckBox x:Name="AllowInvalidCertificateBox" Grid.Row="8" Grid.Column="1" Content="Trust invalid TLS certificate" Margin="0,8" ToolTip="Use only for a server you trust, such as a local test server."/>
        <TextBlock Grid.Row="9" Text="File listing" VerticalAlignment="Center"/><ComboBox x:Name="ListingModeBox" Grid.Row="9" Grid.Column="1" Margin="0,3" Padding="7,4"/>
        <TextBlock x:Name="ErrorText" Grid.Row="10" Grid.ColumnSpan="2" Foreground="#F07178" Margin="0,12,0,0" TextWrapping="Wrap"/>
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" IsCancel="True"/><Button x:Name="AcceptButton" Content="Save" Click="Accept_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
