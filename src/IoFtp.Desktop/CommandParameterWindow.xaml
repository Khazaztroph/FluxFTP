<Window x:Class="IoFtp.Desktop.CommandParameterWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Command parameter" Width="430" Height="190" ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="18" Background="{StaticResource WindowBrush}"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock x:Name="PromptText" FontSize="16" FontWeight="SemiBold"/><TextBox x:Name="ValueBox" Grid.Row="1" Margin="0,12,0,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Cancel" IsCancel="True"/><Button Content="OK" IsDefault="True" Click="Ok_Click"/></StackPanel>
    </Grid>
</Window>
