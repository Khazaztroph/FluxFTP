<Window x:Class="IoFtp.Desktop.CommandsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Commands" Width="680" Height="520" MinWidth="560" MinHeight="420" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="18" Background="{StaticResource WindowBrush}">
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0"><StackPanel Orientation="Horizontal" HorizontalAlignment="Left"><Button Content="Load SITE HELP" Click="LoadSiteHelp_Click"/><Button Content="Import FTPRush XML" Click="Import_Click"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Close" IsCancel="True"/><Button Content="Run command" IsDefault="True" Click="Run_Click"/></StackPanel></Grid>
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <TextBlock Text="SERVER COMMANDS" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="SelectionText" Grid.Row="1" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,14" TextWrapping="Wrap"/>
            <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="Command preset" VerticalAlignment="Center"/><ComboBox x:Name="PresetBox" Grid.Column="1" SelectionChanged="Preset_Changed"/></Grid>
            <Grid Grid.Row="3" Margin="0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="FTP command" VerticalAlignment="Center"/><TextBox x:Name="CommandBox" Grid.Column="1" FontFamily="Cascadia Mono, Consolas"/></Grid>
            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10">
                <TextBox x:Name="OutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" BorderThickness="0" FontFamily="Cascadia Mono, Consolas"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
