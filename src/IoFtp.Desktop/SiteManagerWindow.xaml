<Window x:Class="IoFtp.Desktop.SiteManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Site Manager" Width="720" Height="470" MinWidth="620" MinHeight="380"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <Grid Margin="16" Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <TextBlock Text="Saved sites" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <ListView x:Name="SitesList" Grid.Row="1" MouseDoubleClick="Edit_Click">
            <ListView.View><GridView>
                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="180"/>
                <GridViewColumn Header="Protocol" DisplayMemberBinding="{Binding Protocol}" Width="120"/>
                <GridViewColumn Header="Host" DisplayMemberBinding="{Binding Host}" Width="210"/>
                <GridViewColumn Header="Port" DisplayMemberBinding="{Binding Port}" Width="70"/>
                <GridViewColumn Header="Listing" DisplayMemberBinding="{Binding ListingMode}" Width="120"/>
            </GridView></ListView.View>
        </ListView>
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal"><Button Content="New" Click="New_Click"/><Button Content="Edit" Click="Edit_Click"/><Button Content="Site Options" Click="Options_Click"/><Button Content="Delete" Click="Delete_Click"/></StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Close" IsCancel="True"/><Button Content="Connect" Click="Connect_Click" IsDefault="True"/></StackPanel>
        </Grid>
    </Grid>
</Window>
