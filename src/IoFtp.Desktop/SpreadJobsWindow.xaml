<Window x:Class="IoFtp.Desktop.SpreadJobsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spread Jobs" Width="950" Height="560" MinWidth="720" MinHeight="400" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="14" Background="{StaticResource WindowBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" Margin="0,0,0,8">
            <Grid><TextBlock Text="SPREAD JOBS" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"/><TextBlock Text="Section-based routes" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}"/></Grid>
        </Border>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Add" Click="Add_Click"/><Button Content="Remove" Click="Remove_Click"/><Button Content="Save" Click="Save_Click"/><Button Content="Close" Click="Close_Click"/>
        </StackPanel>
        <DataGrid x:Name="JobsGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="ACTIVE" Binding="{Binding Enabled}" Width="70"/>
                <DataGridTextColumn Header="NAME" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridComboBoxColumn x:Name="SectionColumn" Header="SECTION" SelectedItemBinding="{Binding Section, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridComboBoxColumn x:Name="SourceColumn" Header="SOURCE SITE" SelectedItemBinding="{Binding SourceSite, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                <DataGridTextColumn Header="TARGET SITES (comma separated)" Binding="{Binding TargetSites, UpdateSourceTrigger=PropertyChanged}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
