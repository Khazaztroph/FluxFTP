<Window x:Class="IoFtp.Desktop.AboutWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FluxFTP" Width="1040" Height="720" MinWidth="700" MinHeight="520" MaxWidth="1200" MaxHeight="900" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="24" Background="{StaticResource WindowBrush}">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"><Button Content="Close" MinWidth="72" IsCancel="True" Click="Close_Click"/></StackPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="18" Margin="0,0,0,14">
            <StackPanel><TextBlock><Run Text="Flux" Foreground="{StaticResource AccentBrush}"/><Run Text="FTP"/></TextBlock><TextBlock x:Name="VersionText" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/></StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="True">
            <StackPanel Margin="8,6,18,8">
                <TextBlock Text="FluxFTP is a modern dual-pane FTP, FTPS and FXP client for Windows. It is designed for working with multiple FTP sites, secure server-to-server transfers and ioFTPD workflows." TextWrapping="Wrap" LineHeight="21" Margin="0,0,0,14"/>
                <TextBlock Text="This is an early community release. Keep backups of important configuration and verify transfers before relying on it in production." TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,18"/>
                <TextBlock Text="MAIN FEATURES" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" LineHeight="24" Text="• Two independent panes that can both be Local or Remote&#x0a;• FTP and explicit FTPS (AUTH TLS)&#x0a;• TLS-protected directory listings and file transfers&#x0a;• Direct secure FXP using CPSV/SSCN where supported&#x0a;• Client-relay fallback when direct FXP is unavailable&#x0a;• Multiple reusable login, upload and download slots per site&#x0a;• Transfer queue and transfer-job overview&#x0a;• Live Metrics for sites, slots, jobs, FXP results, speed and traffic&#x0a;• Configurable legend bar: Scrolling, Static, Activity, Compact or Hidden&#x0a;• Drag-and-drop and context-menu queueing between remote sites&#x0a;• STAT -l with LIST fallback, or selectable LIST-only mode&#x0a;• ioFTPD command presets, raw SITE commands and server capabilities&#x0a;• Editable Sections imported from a local ioFTPD installation&#x0a;• Section-based Spread Job configuration&#x0a;• Skiplist and priority-list settings&#x0a;• HTTPS/JSON API with cbftp-compatible endpoints&#x0a;• Dark ioGUI-inspired interface"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
