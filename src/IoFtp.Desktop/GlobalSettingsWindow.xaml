<Window x:Class="IoFtp.Desktop.GlobalSettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Global Settings" Width="720" Height="680" WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Background="{StaticResource WindowBrush}" Foreground="{StaticResource TextBrush}">
    <DockPanel Margin="18" Background="{StaticResource WindowBrush}">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0"><Button Content="Cancel" IsCancel="True"/><Button Content="Save" IsDefault="True" Click="Save_Click"/></StackPanel>
        <StackPanel>
            <TextBlock Text="GLOBAL SETTINGS" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,12"/>
            <TabControl Height="550">
                <TabItem Header="Network"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Bind address/interface"/><TextBox x:Name="BindBox" Grid.Column="1" Margin="0,4" ToolTip="Blank means Windows chooses the interface."/>
                    <TextBlock Grid.Row="1" Text="Active port range from"/><TextBox x:Name="PortFromBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Text="Active port range to"/><TextBox x:Name="PortToBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>
                    <CheckBox x:Name="ApiEnabledBox" Grid.Row="3" Grid.ColumnSpan="2" Content="Enable HTTPS/JSON API" Margin="0,10,0,4"/>
                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal"><TextBlock Text="API port" Width="220"/><TextBox x:Name="ApiPortBox" Width="100"/><CheckBox x:Name="ApiLocalBox" Content="Localhost only" Margin="18,0"/></StackPanel>
                    <TextBlock Grid.Row="5" Text="API password" VerticalAlignment="Center"/><PasswordBox x:Name="ApiPasswordBox" Grid.Row="5" Grid.Column="1" Margin="0,4" Padding="8,5"/>
                </Grid></TabItem>
                <TabItem Header="Jobs &amp; history"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="250"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Prepared job expiration (seconds)"/><TextBox x:Name="ExpirationBox" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="1" Text="Starter timeout (seconds)"/><TextBox x:Name="StarterBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Text="Max transfer runtime (minutes, 0 unlimited)"/><TextBox x:Name="RuntimeBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Text="Transfer job history"/><TextBox x:Name="JobHistoryBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="4" Text="Transfer history"/><TextBox x:Name="TransferHistoryBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="5" Text="Log buffer history"/><TextBox x:Name="LogHistoryBox" Grid.Row="5" Grid.Column="1" Margin="0,4"/>
                </Grid></TabItem>
                <TabItem Header="Site defaults"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Default username"/><TextBox x:Name="UsernameBox" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="1" Text="Default protocol"/><ComboBox x:Name="ProtocolBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Text="Total slots"/><TextBox x:Name="SlotsBox" Grid.Row="2" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="3" Text="Upload slots"/><TextBox x:Name="UploadsBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="4" Text="Download slots"/><TextBox x:Name="DownloadsBox" Grid.Row="4" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="5" Text="Max idle time (seconds)"/><TextBox x:Name="DefaultIdleBox" Grid.Row="5" Grid.Column="1" Margin="0,4"/>
                </Grid></TabItem>
                <TabItem Header="Local"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Local download path"/><TextBox x:Name="LocalPathBox" Grid.Column="1" Margin="0,4"/><TextBlock Grid.Row="1" Text="Local download slots"/><TextBox x:Name="LocalDownloadsBox" Grid.Row="1" Grid.Column="1" Width="100" HorizontalAlignment="Left" Margin="0,4"/><TextBlock Grid.Row="2" Text="Local upload slots"/><TextBox x:Name="LocalUploadsBox" Grid.Row="2" Grid.Column="1" Width="100" HorizontalAlignment="Left" Margin="0,4"/>
                    <CheckBox x:Name="MinimizeToTrayBox" Grid.Row="3" Grid.ColumnSpan="2" Content="Minimize FluxFTP to the system tray" Margin="0,14,0,4"/>
                </Grid></TabItem>
                <TabItem Header="Skiplist"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Files skipped during folder / PRE transfers" FontWeight="SemiBold"/>
                    <TextBox x:Name="SkipPatternsBox" Grid.Row="1" Margin="0,10" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas"/>
                    <TextBlock Grid.Row="2" Text="One wildcard per line, for example *.message or *sample*. Matching files are not queued." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                </Grid></TabItem>
                <TabItem Header="Prio List"><Grid Margin="16"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="PRE / folder upload priority" FontWeight="SemiBold"/>
                    <TextBox x:Name="PriorityPatternsBox" Grid.Row="1" Margin="0,10" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Cascadia Mono, Consolas"/>
                    <TextBlock Grid.Row="2" Text="One wildcard per line. Earlier entries are queued first; for example *.nfo then *.sfv." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
                </Grid></TabItem>
                <TabItem Header="Appearance"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Legend bar mode" VerticalAlignment="Center"/><ComboBox x:Name="LegendModeBox" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Text="Scrolling shows a moving activity summary. Static shows the color legend. Activity shows the latest connection state. Compact shows sites, jobs and speed. Hidden removes the bottom bar."/>
                </Grid></TabItem>
                <TabItem Header="Proxy"><Grid Margin="16"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock Text="Proxy type"/><ComboBox x:Name="ProxyTypeBox" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="1" Text="Host"/><TextBox x:Name="ProxyHostBox" Grid.Row="1" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="2" Text="Port"/><TextBox x:Name="ProxyPortBox" Grid.Row="2" Grid.Column="1" Width="100" HorizontalAlignment="Left" Margin="0,4"/>
                    <TextBlock Grid.Row="3" Text="Username"/><TextBox x:Name="ProxyUsernameBox" Grid.Row="3" Grid.Column="1" Margin="0,4"/>
                    <TextBlock Grid.Row="4" Text="Password"/><PasswordBox x:Name="ProxyPasswordBox" Grid.Row="4" Grid.Column="1" Margin="0,4" Padding="8,5"/>
                    <CheckBox x:Name="ProxyDnsBox" Grid.Row="5" Grid.ColumnSpan="2" Content="Resolve destination hostnames through proxy" Margin="0,10,0,4"/>
                    <CheckBox x:Name="ProxyDataBox" Grid.Row="6" Grid.ColumnSpan="2" Content="Use proxy for PASV/EPSV data connections" Margin="0,4"/>
                    <TextBlock Grid.Row="7" Grid.ColumnSpan="2" Margin="0,14,0,0" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Text="Direct FXP data remains server-to-server. Active-mode incoming connections cannot be routed through this proxy."/>
                    <Button Grid.Row="8" Grid.Column="1" Content="Test proxy" HorizontalAlignment="Left" Margin="0,14,0,0" Click="TestProxy_Click"/>
                </Grid></TabItem>
            </TabControl>
            <TextBlock x:Name="ErrorText" Foreground="#F07178" Margin="0,8"/>
        </StackPanel>
    </DockPanel>
</Window>
